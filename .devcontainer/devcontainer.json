{
  "name": "Sage Monorepo Dev Container",
  "image": "ghcr.io/sage-bionetworks/sage-monorepo-devcontainer:sha-a31e971a462a676420ba42e7335ea92994239041",
  "containerEnv": {
    "DOCKER_PASSWORD": "${localEnv:DOCKER_PASSWORD}",
    "DOCKER_USERNAME": "${localEnv:DOCKER_USERNAME}",
    "NX_BASE": "${localEnv:NX_BASE}",
    "NX_BRANCH": "${localEnv:NX_BRANCH}",
    "NX_CI_EXECUTION_ENV": "${localEnv:NX_CI_EXECUTION_ENV}",
    "NX_CLOUD_ACCESS_TOKEN": "${localEnv:NX_CLOUD_ACCESS_TOKEN}",
    "NX_CLOUD_ENCRYPTION_KEY": "${localEnv:NX_CLOUD_ENCRYPTION_KEY}",
    "NX_HEAD": "${localEnv:NX_HEAD}",
    "SENTRY_AUTH_TOKEN": "${localEnv:SENTRY_AUTH_TOKEN}",
    "SONAR_PULL_REQUEST_NUMBER": "${localEnv:SONAR_PULL_REQUEST_NUMBER}",
    "SONAR_TOKEN": "${localEnv:SONAR_TOKEN}",
    "UV_CACHE_DIR": "${containerWorkspaceFolder}/.cache/uv"
  },
  "features": {},
  "forwardPorts": [
    2000, 2432, 3333, 3334, 4200, 4211, 4400, 4401, 4402, 5200, 8000, 8010, 8080, 8100, 8111, 8112,
    8113, 8114, 8115, 8116, 8200, 8500, 8501, 8502, 8503, 8504, 8505, 8506, 8507, 8508, 8509, 8510,
    8511, 21000, 27017
