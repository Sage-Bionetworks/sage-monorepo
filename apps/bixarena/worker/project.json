{
  "name": "bixarena-worker",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "targets": {
    "create-config": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cp -n .env.example .env",
        "cwd": "{projectRoot}"
      }
    },
    "build": {
      "executor": "@nxlv/python:build",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "outputPath": "{projectRoot}/dist",
        "publish": false,
        "lockedVersions": true,
        "bundleLocalDependencies": true
      }
    },
    "serve-detach": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker/bixarena/serve-detach.sh {projectName}"
      },
      "dependsOn": ["^build"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run ruff check leaderboard_snapshot/",
        "cwd": "{projectRoot}"
      }
    },
    "export-image-tarball": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker save ghcr.io/sage-bionetworks/bixarena-worker:local -o /tmp/bixarena-worker.tar"
      },
      "dependsOn": ["build-image"]
    },
    "invoke": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run python -m leaderboard_snapshot.handler",
        "cwd": "{projectRoot}"
      }
    }
  },
  "tags": ["language:python", "type:worker", "package-manager:uv"],
  "implicitDependencies": ["bixarena-leaderboard"]
}
