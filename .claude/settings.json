{
  "permissions": {
    "allow": [
      "Bash(python3 -c \"import yaml; yaml.safe_load\\(open\\(''libs/bixarena/api-description/openapi/openapi.yaml''\\)\\); print\\(''Valid YAML''\\)\")",
      "Bash(git add:*)",
      "Bash(git rebase:*)",
      "Bash(GIT_EDITOR=true git rebase --continue)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(./**/*.env)",
      "Read(./secrets/**)",
      "Read(./**/secrets/**)",
      "Read(./cookies.txt)",
      "Read(./**/*token*)",
      "Read(./**/*apikey*)",
      "Read(./**/*api-key*)",
      "Read(./**/*.key)",
      "Read(./**/*.pem)",
      "Read(./**/*.p12)",
      "Read(./**/*.pfx)",
      "Read(./credentials.json)",
      "Read(./**/credentials.json)",
      "Read(./.aws/credentials)",
      "Read(./.aws/config)"
    ]
  }
}
